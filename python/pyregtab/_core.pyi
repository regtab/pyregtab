ContentSpec = Union[
    "AtomicContentSpec",
    "DelimitedContentSpec",
    "CompoundContentSpec",
    "ConditionalContentSpec",
]

class AtomicContentSpec:
    idd: ItemDerivationDirective
    tags: list[str]
    def __init__(
        self,
        idd: ItemDerivationDirective,
        extractor: Optional[StringExtractor] = None,
        tags: Sequence[str] = (),
        actions: Sequence[ActionSpec] = (),
    ) -> None: ...
    @staticmethod
    def val(
        *actions: ActionSpec, extractor: Optional[StringExtractor] = None
    ) -> AtomicContentSpec: ...
    @staticmethod
    def attr(
        *actions: ActionSpec, extractor: Optional[StringExtractor] = None
    ) -> AtomicContentSpec: ...
    @staticmethod
    def aux(
        *actions: ActionSpec, extractor: Optional[StringExtractor] = None
    ) -> AtomicContentSpec: ...
    @staticmethod
    def skip() -> AtomicContentSpec: ...
    @staticmethod
    def val_tagged(
        tag: Union[str, Sequence[str]], *actions: ActionSpec
    ) -> AtomicContentSpec: ...
    def tagged(self, *new_tags: str) -> AtomicContentSpec: ...
    def extract(self, extractor: StringExtractor) -> AtomicContentSpec: ...
    def split_by(self, delimiter: str) -> DelimitedContentSpec: ...
    def then(self, delimiter: str, next: ContentSpec) -> CompoundContentSpec: ...

class DelimitedContentSpec:
    delimiter: str
    atomic_spec: AtomicContentSpec
    def __init__(self, delimiter: str, atomic_spec: AtomicContentSpec) -> None: ...
    def then(self, delimiter: str, next: ContentSpec) -> CompoundContentSpec: ...

class CompoundContentSpec:
