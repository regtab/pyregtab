    ) -> None: ...
    @staticmethod
    def of(
        first: ContentSpec, *rest: tuple[str, ContentSpec]
    ) -> CompoundContentSpec: ...
    def then(self, delimiter: str, next: ContentSpec) -> CompoundContentSpec: ...

